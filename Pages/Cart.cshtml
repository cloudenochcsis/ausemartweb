@page
@model CartModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<!-- Cart Header -->
<div class="hero-section" style="padding: 3rem 0;">
    <div class="container">
        <h1 class="display-4">Your Shopping Cart</h1>
        <p class="lead">Review your items before checkout</p>
    </div>
</div>

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 fade-in">
            <!-- Cart Items -->
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0 fs-4">Cart Items (3)</h3>
                    <button class="btn btn-outline-danger btn-sm">
                        <i class="fas fa-trash-alt me-1"></i> Clear Cart
                    </button>
                </div>
                <div class="card-body p-0">
                    <!-- Cart Item 1 -->
                    <div class="d-flex p-3 border-bottom">
                        <div class="flex-shrink-0">
                            <img src="/images/kangaroo.jpg" alt="Product" class="rounded" width="100" height="100" style="object-fit: cover;">
                        </div>
                        <div class="flex-grow-1 ms-3 d-flex flex-column">
                            <div class="d-flex justify-content-between">
                                <h5 class="fw-bold">Premium Australian Beef Jerky</h5>
                                <h5 class="fw-bold">$29.99</h5>
                            </div>
                            <p class="text-muted mb-2 small">Size: 250g | Flavor: Original</p>
                            <div class="d-flex mt-auto justify-content-between align-items-center">
                                <div class="input-group input-group-sm" style="width: 120px;">
                                    <button class="btn btn-outline-secondary" type="button">-</button>
                                    <input type="text" class="form-control text-center" value="1">
                                    <button class="btn btn-outline-secondary" type="button">+</button>
                                </div>
                                <div>
                                    <button class="btn btn-sm text-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cart Item 2 -->
                    <div class="d-flex p-3 border-bottom">
                        <div class="flex-shrink-0">
                            <img src="/images/koala.jpg" alt="Product" class="rounded" width="100" height="100" style="object-fit: cover;">
                        </div>
                        <div class="flex-grow-1 ms-3 d-flex flex-column">
                            <div class="d-flex justify-content-between">
                                <h5 class="fw-bold">Australian Wool Throw Blanket</h5>
                                <h5 class="fw-bold">$89.95</h5>
                            </div>
                            <p class="text-muted mb-2 small">Color: Eucalyptus Green | Material: 100% Merino Wool</p>
                            <div class="d-flex mt-auto justify-content-between align-items-center">
                                <div class="input-group input-group-sm" style="width: 120px;">
                                    <button class="btn btn-outline-secondary" type="button">-</button>
                                    <input type="text" class="form-control text-center" value="1">
                                    <button class="btn btn-outline-secondary" type="button">+</button>
                                </div>
                                <div>
                                    <button class="btn btn-sm text-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cart Item 3 -->
                    <div class="d-flex p-3">
                        <div class="flex-shrink-0">
                            <img src="/images/spider.jpg" alt="Product" class="rounded" width="100" height="100" style="object-fit: cover;">
                        </div>
                        <div class="flex-grow-1 ms-3 d-flex flex-column">
                            <div class="d-flex justify-content-between">
                                <h5 class="fw-bold">Handcrafted Boomerang</h5>
                                <h5 class="fw-bold">$45.50</h5>
                            </div>
                            <p class="text-muted mb-2 small">Material: Australian Hardwood | Size: Medium (40cm)</p>
                            <div class="d-flex mt-auto justify-content-between align-items-center">
                                <div class="input-group input-group-sm" style="width: 120px;">
                                    <button class="btn btn-outline-secondary" type="button">-</button>
                                    <input type="text" class="form-control text-center" value="1">
                                    <button class="btn btn-outline-secondary" type="button">+</button>
                                </div>
                                <div>
                                    <button class="btn btn-sm text-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Continue Shopping -->
            <div class="d-flex justify-content-between mb-4">
                <a href="/Products" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-2"></i> Continue Shopping
                </a>
                <button class="btn btn-outline-primary">
                    <i class="fas fa-sync-alt me-2"></i> Update Cart
                </button>
            </div>
            
            <!-- You might also like -->
            <div class="mb-5">
                <h4 class="mb-3">You might also like</h4>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 border-0 shadow-sm">
                            <img src="/images/kangaroo.jpg" class="card-img-top" style="height: 140px; object-fit: cover;" alt="Product">
                            <div class="card-body">
                                <h6 class="card-title">Australian Bush Spices Set</h6>
                                <p class="fw-bold mb-0">$34.95</p>
                                <button class="btn btn-sm btn-outline-primary mt-2">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 border-0 shadow-sm">
                            <img src="/images/koala.jpg" class="card-img-top" style="height: 140px; object-fit: cover;" alt="Product">
                            <div class="card-body">
                                <h6 class="card-title">Eucalyptus Essential Oil</h6>
                                <p class="fw-bold mb-0">$18.99</p>
                                <button class="btn btn-sm btn-outline-primary mt-2">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 border-0 shadow-sm">
                            <img src="/images/spider.jpg" class="card-img-top" style="height: 140px; object-fit: cover;" alt="Product">
                            <div class="card-body">
                                <h6 class="card-title">Aboriginal Art Print</h6>
                                <p class="fw-bold mb-0">$59.95</p>
                                <button class="btn btn-sm btn-outline-primary mt-2">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 fade-in">
            <!-- Order Summary -->
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="mb-0 fs-4">Order Summary</h3>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal:</span>
                        <span>$165.44</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping:</span>
                        <span>$12.95</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tax:</span>
                        <span>$16.54</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4 fw-bold">
                        <span>Total:</span>
                        <span class="fs-5">$194.93</span>
                    </div>
                    <button class="btn btn-primary w-100 py-2 mb-3">
                        <i class="fas fa-credit-card me-2"></i> Proceed to Checkout
                    </button>
                    <div class="text-center mt-3">
                        <div class="text-muted small mb-2">We Accept</div>
                        <div class="d-flex justify-content-center gap-2">
                            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/visa/visa-original.svg" width="40" alt="Visa">
                            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mastercard/mastercard-original.svg" width="40" alt="Mastercard">
                            <i class="fab fa-cc-amex fa-2x text-muted"></i>
                            <i class="fab fa-cc-paypal fa-2x text-muted"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Promo Code -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0 fs-5">Apply Promo Code</h5>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Enter code">
                        <button class="btn btn-primary" type="button">Apply</button>
                    </div>
                    <div class="alert alert-light p-2 mb-0 text-center">
                        <small><i class="fas fa-info-circle me-1"></i> Free shipping on orders over $150</small>
                    </div>
                </div>
            </div>
            
            <!-- Secure Checkout -->
            <div class="mt-4 text-center">
                <div class="d-flex align-items-center justify-content-center mb-2">
                    <i class="fas fa-lock me-2 text-success"></i>
                    <span class="fw-bold">Secure Checkout</span>
                </div>
                <p class="small text-muted mb-0">Your payment information is processed securely. We do not store credit card details nor have access to your credit card information.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add fade-in animation
        document.addEventListener('DOMContentLoaded', function() {
            const elements = document.querySelectorAll('.fade-in');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = 1;
                    }
                });
            });
            
            elements.forEach(element => {
                element.style.opacity = 0;
                observer.observe(element);
            });
        });
    </script>
}
