@page
@model AboutModel
@{
    ViewData["Title"] = "About";
}

<!-- About Header -->
<div class="hero-section" style="padding: 3rem 0;">
    <div class="container">
        <h1 class="display-4">About Aus-E-Mart</h1>
        <p class="lead">Bringing the best of Australia to the world since 2020</p>
    </div>
</div>

<div class="container my-5">
    <!-- Our Story Section -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <h2>Our Story</h2>
            <p>Founded in 2020, Aus-E-Mart started with a simple mission: to bring authentic Australian products to customers worldwide. What began as a small operation in Sydney has grown into a nationwide network of partnerships with local artisans, food producers, and businesses across Australia.</p>
            <p>Our team is passionate about showcasing the quality, craftsmanship, and unique character of Australian-made goods. We personally select each item in our collection to ensure it represents the best of what Australia has to offer.</p>
            <p>Today, we're proud to serve customers in over 30 countries, providing them with a taste of Australia's rich culture, natural ingredients, and exceptional products.</p>
        </div>
        <div class="col-lg-6">
            <img src="/images/kangaroo.jpg" alt="Aus-E-Mart Story" class="img-fluid rounded shadow-sm">
        </div>
    </div>

    <!-- Our Values Section -->
    <div class="row my-5">
        <div class="col-12 text-center mb-4">
            <h2>Our Values</h2>
            <p class="lead">The principles that guide everything we do</p>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="fas fa-leaf text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                    <h3>Sustainability</h3>
                    <p>We're committed to environmentally responsible practices in sourcing, packaging, and shipping our products.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="fas fa-handshake text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                    <h3>Authenticity</h3>
                    <p>Every product we sell is genuinely Australian, often handcrafted by local artisans and producers.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="fas fa-heart text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                    <h3>Community</h3>
                    <p>We support Australian communities by partnering with small businesses and contributing to local initiatives.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Our Team Section -->
    <div class="row my-5">
        <div class="col-12 text-center mb-4">
            <h2>Our Team</h2>
            <p class="lead">Meet the passionate people behind Aus-E-Mart</p>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card border-0 shadow-sm">
                <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="Team Member" class="card-img-top">
                <div class="card-body text-center">
                    <h5 class="mb-1">Sarah Johnson</h5>
                    <p class="text-muted mb-2">Co-Founder & CEO</p>
                    <div class="social-links">
                        <a href="#" class="text-decoration-none me-2"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-decoration-none"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card border-0 shadow-sm">
                <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Team Member" class="card-img-top">
                <div class="card-body text-center">
                    <h5 class="mb-1">Michael Chen</h5>
                    <p class="text-muted mb-2">Co-Founder & COO</p>
                    <div class="social-links">
                        <a href="#" class="text-decoration-none me-2"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-decoration-none"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card border-0 shadow-sm">
                <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Team Member" class="card-img-top">
                <div class="card-body text-center">
                    <h5 class="mb-1">Emma Thompson</h5>
                    <p class="text-muted mb-2">Product Curator</p>
                    <div class="social-links">
                        <a href="#" class="text-decoration-none me-2"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-decoration-none"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card border-0 shadow-sm">
                <img src="https://randomuser.me/api/portraits/men/75.jpg" alt="Team Member" class="card-img-top">
                <div class="card-body text-center">
                    <h5 class="mb-1">David Wilson</h5>
                    <p class="text-muted mb-2">Customer Experience</p>
                    <div class="social-links">
                        <a href="#" class="text-decoration-none me-2"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-decoration-none"><i class="fas fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="card bg-light border-0 mt-5" style="background: linear-gradient(135deg, rgba(0,114,178,0.05) 0%, rgba(0,132,61,0.05) 100%) !important;">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <h3>Get in Touch</h3>
                    <p>We'd love to hear from you! Whether you have a question about our products, need assistance with an order, or want to explore partnership opportunities, our team is here to help.</p>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 123 Market Street, Sydney, NSW 2000, Australia</li>
                        <li class="mb-2"><i class="fas fa-phone me-2 text-primary"></i> +61 2 1234 5678</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i> support@ausemart.com</li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <form>
                        <div class="mb-3">
                            <input type="text" class="form-control" placeholder="Your Name">
                        </div>
                        <div class="mb-3">
                            <input type="email" class="form-control" placeholder="Your Email">
                        </div>
                        <div class="mb-3">
                            <select class="form-select">
                                <option selected>Select a topic</option>
                                <option>Product Inquiry</option>
                                <option>Order Status</option>
                                <option>Partnership Opportunity</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <textarea class="form-control" rows="4" placeholder="Your Message"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>