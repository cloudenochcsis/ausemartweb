@page
@model ausemartweb.Pages.ProfilePageModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container" style="margin-top: 100px; min-height: 70vh;">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="display-5">My Profile</h1>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="fas fa-edit me-2"></i>Edit Profile
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <strong>Full Name:</strong>
                        </div>
                        <div class="col-sm-9">
                            @Model.UserInfo?.FirstName @Model.UserInfo?.LastName
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <strong>Email:</strong>
                        </div>
                        <div class="col-sm-9">
                            @Model.UserInfo?.Email
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3">
                            <strong>Member Since:</strong>
                        </div>
                        <div class="col-sm-9">
                            @Model.UserInfo?.CreatedAt.ToString("MMMM dd, yyyy")
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3">
                            <strong>Account Status:</strong>
                        </div>
                        <div class="col-sm-9">
                            <span class="badge bg-success">Active</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Account Summary</h5>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        <h3 class="text-primary">0</h3>
                        <small class="text-muted">Total Orders</small>
                    </div>
                    <div class="mb-3">
                        <h3 class="text-success">$0.00</h3>
                        <small class="text-muted">Total Spent</small>
                    </div>
                    <div class="mb-3">
                        <h3 class="text-warning">0</h3>
                        <small class="text-muted">Items in Cart</small>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="fas fa-cogs me-2"></i>Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-page="/Orders" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-shopping-bag me-2"></i>View Orders
                        </a>
                        <a asp-page="/Cart" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-shopping-cart me-2"></i>View Cart
                        </a>
                        <a asp-page="/Products" class="btn btn-outline-success btn-sm">
                            <i class="fas fa-store me-2"></i>Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="UpdateProfile.FirstName" class="form-label">First Name</label>
                        <input asp-for="UpdateProfile.FirstName" class="form-control" value="@Model.UserInfo?.FirstName" />
                        <span asp-validation-for="UpdateProfile.FirstName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateProfile.LastName" class="form-label">Last Name</label>
                        <input asp-for="UpdateProfile.LastName" class="form-control" value="@Model.UserInfo?.LastName" />
                        <span asp-validation-for="UpdateProfile.LastName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UpdateProfile.Email" class="form-label">Email</label>
                        <input asp-for="UpdateProfile.Email" class="form-control" value="@Model.UserInfo?.Email" />
                        <span asp-validation-for="UpdateProfile.Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 