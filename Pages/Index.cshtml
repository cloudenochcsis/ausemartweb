@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7 fade-in">
                <h1 class="display-4">G'day, Welcome to Aus-E-Mart</h1>
                <p class="lead mb-4">Discover authentic Australian products shipped directly to your doorstep. From gourmet foods to unique crafts, we bring the best of Australia to you.</p>
                <div class="d-flex gap-2">
                    <a href="/Products" class="btn btn-primary btn-lg">
                        Explore Products <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                    <a href="#featured" class="btn btn-outline-light btn-lg">
                        Today's Deals <i class="fas fa-tag ms-2"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center fade-in">
                <img src="https://img.icons8.com/external-flaticons-lineal-color-flat-icons/512/null/external-kangaroo-animal-flaticons-lineal-color-flat-icons-2.png" alt="Australia" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container my-5">
    <div class="row">
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-shipping-fast text-primary" style="font-size: 2.5rem;"></i>
                </div>
                <h3>Fast Shipping</h3>
                <p>Express delivery from Australia to anywhere in the world with tracking included.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-check-circle text-primary" style="font-size: 2.5rem;"></i>
                </div>
                <h3>Authentic Products</h3>
                <p>100% genuine Aussie products sourced directly from local artisans and suppliers.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-headset text-primary" style="font-size: 2.5rem;"></i>
                </div>
                <h3>24/7 Support</h3>
                <p>Our friendly customer service team is always ready to assist with any inquiries.</p>
            </div>
        </div>
    </div>
</div>

<!-- Featured Categories Section -->
<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Featured Categories</h2>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <img src="/images/kangaroo.jpg" class="card-img-top" alt="Gourmet Foods">
                <div class="card-body">
                    <h3 class="card-title">Gourmet Foods</h3>
                    <p class="card-text">Experience the unique tastes of Australia with our premium selection of gourmet foods.</p>
                    <a href="/Products" class="btn btn-outline-primary">Explore Foods</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <img src="/images/koala.jpg" class="card-img-top" alt="Home & Gifts">
                <div class="card-body">
                    <h3 class="card-title">Home & Gifts</h3>
                    <p class="card-text">Discover beautiful Australian-made home decor and unique gift ideas.</p>
                    <a href="/Products" class="btn btn-outline-primary">View Collection</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <img src="/images/spider.jpg" class="card-img-top" alt="Souvenirs">
                <div class="card-body">
                    <h3 class="card-title">Aussie Souvenirs</h3>
                    <p class="card-text">Take home a piece of Australia with our authentic souvenirs and memorabilia.</p>
                    <a href="/Products" class="btn btn-outline-primary">Shop Souvenirs</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Newsletter Section -->
<div class="container my-5">
    <div class="card bg-light border-0" style="border-radius: var(--border-radius); background: linear-gradient(135deg, rgba(0,114,178,0.05) 0%, rgba(0,132,61,0.05) 100%);">
        <div class="card-body p-4 text-center">
            <h2 class="mb-3">Stay Updated with Aus-E-Mart</h2>
            <p class="lead mb-4">Subscribe to our newsletter for exclusive deals, new product announcements, and Australian travel tips.</p>
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="input-group mb-3">
                        <input type="email" class="form-control" placeholder="Your email address" style="padding: 10px 15px;">
                        <button class="btn btn-primary" type="button">
                            <i class="fas fa-paper-plane me-2"></i> Subscribe
                        </button>
                    </div>
                    <small class="text-muted">We respect your privacy and will never share your information.</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add fade-in animation to elements as they come into viewport
        document.addEventListener('DOMContentLoaded', function() {
            const elements = document.querySelectorAll('.fade-in');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = 1;
                    }
                });
            });
            
            elements.forEach(element => {
                element.style.opacity = 0;
                observer.observe(element);
            });
        });
    </script>
}
