@page
@model ContactModel
@{
    ViewData["Title"] = "Contact ToyLand - Get in Touch";
    ViewData["Description"] = "Contact ToyLand for questions about toys, orders, or customer service. We're here to help make playtime magical!";
}

<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="display-4 fade-in">Get in Touch!</h1>
                    <p class="lead mb-4 fade-in delay-1">
                        We'd love to hear from you! Whether you have questions about our toys, 
                        need help with an order, or just want to share your child's joy - we're here to help.
                    </p>
                    <div class="hero-stats fade-in delay-2">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="stat-item">
                                    <h3 class="text-white mb-1">24/7</h3>
                                    <small>Support</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="stat-item">
                                    <h3 class="text-white mb-1">&lt;1hr</h3>
                                    <small>Response</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="stat-item">
                                    <h3 class="text-white mb-1">100%</h3>
                                    <small>Satisfaction</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://img.icons8.com/fluency/300/null/customer-support.png" 
                     alt="Customer Support" class="hero-image fade-in delay-3" />
            </div>
        </div>
    </div>
</div>

<!-- Contact Section -->
<section class="py-5">
    <div class="container">
        <!-- Success/Error Messages -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        
        <div class="row">
            <!-- Contact Form -->
            <div class="col-lg-8 mb-5">
                <div class="card shadow-lg border-0">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">
                            <i class="fas fa-paper-plane me-2"></i>
                            Send us a Message
                        </h3>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" class="contact-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ContactInfo.FirstName" class="form-label">First Name *</label>
                                    <input asp-for="ContactInfo.FirstName" class="form-control" />
                                    <span asp-validation-for="ContactInfo.FirstName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ContactInfo.LastName" class="form-label">Last Name *</label>
                                    <input asp-for="ContactInfo.LastName" class="form-control" />
                                    <span asp-validation-for="ContactInfo.LastName" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ContactInfo.Email" class="form-label">Email Address *</label>
                                    <input asp-for="ContactInfo.Email" class="form-control" />
                                    <span asp-validation-for="ContactInfo.Email" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ContactInfo.Phone" class="form-label">Phone Number</label>
                                    <input asp-for="ContactInfo.Phone" class="form-control" />
                                    <span asp-validation-for="ContactInfo.Phone" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label asp-for="ContactInfo.Subject" class="form-label">Subject *</label>
                                <select asp-for="ContactInfo.Subject" class="form-control">
                                    <option value="">Select a topic...</option>
                                    <option value="product-inquiry">Product Inquiry</option>
                                    <option value="order-support">Order Support</option>
                                    <option value="shipping">Shipping & Delivery</option>
                                    <option value="returns">Returns & Exchanges</option>
                                    <option value="complaint">Complaint</option>
                                    <option value="compliment">Compliment</option>
                                    <option value="partnership">Partnership</option>
                                    <option value="other">Other</option>
                                </select>
                                <span asp-validation-for="ContactInfo.Subject" class="text-danger"></span>
                            </div>
                            
                            <div class="mb-3">
                                <label asp-for="ContactInfo.OrderNumber" class="form-label">Order Number (if applicable)</label>
                                <input asp-for="ContactInfo.OrderNumber" class="form-control" placeholder="e.g., TOY-12345" />
                                <span asp-validation-for="ContactInfo.OrderNumber" class="text-danger"></span>
                            </div>
                            
                            <div class="mb-4">
                                <label asp-for="ContactInfo.Message" class="form-label">Message *</label>
                                <textarea asp-for="ContactInfo.Message" class="form-control" rows="5" 
                                          placeholder="Tell us how we can help you..."></textarea>
                                <span asp-validation-for="ContactInfo.Message" class="text-danger"></span>
                            </div>
                            
                            <div class="mb-3">
                                <div class="form-check">
                                    <input asp-for="ContactInfo.Newsletter" class="form-check-input" />
                                    <label asp-for="ContactInfo.Newsletter" class="form-check-label">
                                        Subscribe to our newsletter for toy updates and special offers
                                    </label>
                                </div>
                            </div>
                            
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-paper-plane me-2"></i>
                                    Send Message
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            
            <!-- Contact Information -->
            <div class="col-lg-4">
                <!-- Business Hours -->
                <div class="card mb-4 shadow border-0">
                    <div class="card-header bg-accent text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-clock me-2"></i>
                            Business Hours
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="hours-list">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Monday - Friday</span>
                                <span class="fw-bold">9:00 AM - 8:00 PM</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Saturday</span>
                                <span class="fw-bold">10:00 AM - 6:00 PM</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Sunday</span>
                                <span class="fw-bold">12:00 PM - 5:00 PM</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <span class="text-primary fw-bold">Holidays</span>
                                <span class="text-muted">Reduced Hours</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Contact Methods -->
                <div class="card mb-4 shadow border-0">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-phone me-2"></i>
                            Contact Methods
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="contact-methods">
                            <div class="contact-item mb-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-phone-alt text-primary me-3"></i>
                                    <div>
                                        <strong>Phone</strong><br>
                                        <a href="tel:+61234567890" class="text-decoration-none">+61 2 3456 7890</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="contact-item mb-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-envelope text-primary me-3"></i>
                                    <div>
                                        <strong>Email</strong><br>
                                        <a href="mailto:hello@toyland.com.au" class="text-decoration-none">hello@toyland.com.au</a>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="contact-item mb-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-comments text-primary me-3"></i>
                                    <div>
                                        <strong>Live Chat</strong><br>
                                        <span class="text-success">Online Now</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="contact-item">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-map-marker-alt text-primary me-3"></i>
                                    <div>
                                        <strong>Address</strong><br>
                                        123 Toy Street<br>
                                        Sydney NSW 2000<br>
                                        Australia
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Social Media -->
                <div class="card shadow border-0">
                    <div class="card-header bg-purple text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-share-alt me-2"></i>
                            Follow Us
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        <div class="social-buttons">
                            <a href="#" class="btn btn-outline-primary btn-sm me-2 mb-2">
                                <i class="fab fa-facebook-f"></i> Facebook
                            </a>
                            <a href="#" class="btn btn-outline-info btn-sm me-2 mb-2">
                                <i class="fab fa-twitter"></i> Twitter
                            </a>
                            <a href="#" class="btn btn-outline-danger btn-sm me-2 mb-2">
                                <i class="fab fa-instagram"></i> Instagram
                            </a>
                            <a href="#" class="btn btn-outline-success btn-sm me-2 mb-2">
                                <i class="fab fa-whatsapp"></i> WhatsApp
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Frequently Asked Questions</h2>
            <p class="lead">Quick answers to common questions</p>
        </div>
        
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item mb-3 border-0 shadow-sm">
                        <h3 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How long does shipping take?
                            </button>
                        </h3>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Standard shipping takes 3-5 business days. Express shipping is available for 1-2 business days. 
                                Free shipping on orders over $50!
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item mb-3 border-0 shadow-sm">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                What's your return policy?
                            </button>
                        </h3>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                We offer 30-day returns on unopened items in original packaging. 
                                Simply contact us for a return label and we'll take care of the rest.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item mb-3 border-0 shadow-sm">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                Are your toys safe for children?
                            </button>
                        </h3>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Absolutely! All our toys meet Australian safety standards (AS/NZS ISO 8124) and are tested for safety. 
                                Age recommendations are clearly marked on each product.
                            </div>
                        </div>
                    </div>
                    
                    <div class="accordion-item border-0 shadow-sm">
                        <h3 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Do you offer gift wrapping?
                            </button>
                        </h3>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Yes! We offer beautiful gift wrapping for $5 per item. You can also include a personalized gift message. 
                                Perfect for birthdays and special occasions!
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 