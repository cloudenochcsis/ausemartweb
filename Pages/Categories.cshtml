@page
@model IndexModel
@{
    ViewData["Title"] = "Categories";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 fade-in hero-content">
                <h1 class="display-4">Toy Categories</h1>
                <p class="lead mb-4">Explore our wide range of toy categories for every age, interest, and play style!</p>
                <div class="d-flex gap-3">
                    <a href="#categories" class="btn btn-primary btn-lg">
                        Browse Categories <i class="fas fa-th-large ms-2"></i>
                    </a>
                    <a href="/Products" class="btn btn-accent btn-lg">
                        View All Toys <i class="fas fa-puzzle-piece ms-2"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center fade-in">
                <img src="https://img.icons8.com/fluency/512/null/categorize.png" alt="Categories" class="img-fluid hero-image" style="max-height: 350px;">
            </div>
        </div>
    </div>
</div>

<!-- Main Categories Section -->
