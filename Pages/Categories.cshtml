                    <div class="category-overlay">
                        <h3 class="category-title">Plush Toys</h3>
                        <p>Soft, cuddly companions for all ages</p>
                        <a href="/Products" class="btn btn-light">Explore <i class="fas fa-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Category 2: Building Blocks -->
