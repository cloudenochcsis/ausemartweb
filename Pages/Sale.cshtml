                            <div class="col-lg-6 mb-4 mb-lg-0">
                                <h2 style="font-family: 'Fredoka One', cursive;">Never Miss a Sale!</h2>
                                <p class="lead">Subscribe to our newsletter to get notified about upcoming sales and special offers!</p>
                                <ul class="list-unstyled">
                                    <li><i class="fas fa-check-circle me-2"></i> Early access to sales</li>
                                    <li><i class="fas fa-check-circle me-2"></i> Exclusive subscriber discounts</li>
                                    <li><i class="fas fa-check-circle me-2"></i> Special clearance alerts</li>
                                </ul>
                            </div>
                            <div class="col-lg-6">
                                <div class="card border-0 shadow-lg rounded-4">
                                    <div class="card-body p-4">
                                        <form>
                                            <div class="mb-3">
                                                <label for="email" class="form-label text-dark">Email Address</label>
                                                <input type="email" class="form-control" id="email" placeholder="Enter your email">
                                            </div>
                                            <div class="mb-3">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="agree">
                                                    <label class="form-check-label text-dark" for="agree">
