@page
@model IndexModel
@{
    ViewData["Title"] = "Sale";
}

<!-- Hero Section -->
<div class="hero-section" style="background: linear-gradient(135deg, var(--toy-secondary) 0%, var(--toy-purple) 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 fade-in hero-content">
                <h1 class="display-4">Toy Sale!</h1>
                <p class="lead mb-4">Incredible savings on your favorite toys! Limited time offers you don't want to miss.</p>
                <div class="d-flex gap-3">
                    <a href="#sale-items" class="btn btn-primary btn-lg">
                        Shop Sale <i class="fas fa-tag ms-2"></i>
                    </a>
                    <a href="#clearance" class="btn btn-accent btn-lg">
                        Clearance Items <i class="fas fa-fire ms-2"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center fade-in">
                <img src="https://img.icons8.com/fluency/512/null/sale.png" alt="Sale" class="img-fluid hero-image" style="max-height: 350px;">
            </div>
        </div>
    </div>
</div>

<!-- Sale Timer Section -->
<div class="container my-5 text-center">
    <div class="card border-0 rounded-4 overflow-hidden shadow-lg">
        <div class="card-body p-4" style="background-color: var(--toy-secondary); color: white;">
            <h2 style="font-family: 'Fredoka One', cursive;">Flash Sale Ends In:</h2>
            <div class="countdown-timer d-flex justify-content-center gap-4 my-4">
                <div class="countdown-item">
                    <div class="countdown-value">2</div>
                    <div class="countdown-label">Days</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-value">14</div>
                    <div class="countdown-label">Hours</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-value">36</div>
                    <div class="countdown-label">Minutes</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-value">52</div>
                    <div class="countdown-label">Seconds</div>
                </div>
            </div>
            <p class="lead">Use code <span class="promo-code">TOYFUN25</span> for an EXTRA 25% OFF!</p>
        </div>
    </div>
</div>

