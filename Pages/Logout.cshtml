@page
@model ausemartweb.Pages.LogoutPageModel
@{
    ViewData["Title"] = "Logout";
}

<div class="container text-center" style="margin-top: 150px; min-height: 50vh;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body py-5">
                    <i class="fas fa-sign-out-alt fa-4x text-primary mb-4"></i>
                    <h3 class="mb-3">Logging Out...</h3>
                    <p class="text-muted mb-4">You are being signed out of your account.</p>
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Automatically redirect after a short delay to show the logout page
    setTimeout(function() {
        window.location.href = '@Url.Page("/Login")';
    }, 2000);
</script> 