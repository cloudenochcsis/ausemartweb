@page
@model ProductsModel
@{
    ViewData["Title"] = "Products";
}

<!-- Products Header -->
<div class="hero-section" style="padding: 3rem 0;">
    <div class="container">
        <h1 class="display-4">Explore Our Products</h1>
        <p class="lead">Authentic Australian goods shipped directly to your doorstep</p>
    </div>
</div>

<div class="container my-5">
    <!-- Filter and Search Row -->
    <div class="row mb-4">
        <div class="col-md-6 mb-3 mb-md-0">
            <div class="d-flex">
                <select class="form-select me-2">
                    <option selected>All Categories</option>
                    <option>Gourmet Foods</option>
                    <option>Home & Gifts</option>
                    <option>Souvenirs</option>
                    <option>Australian Fashion</option>
                    <option>Native Ingredients</option>
                </select>
                <select class="form-select">
                    <option selected>Sort By: Featured</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Newest First</option>
                    <option>Best Selling</option>
                </select>
            </div>
        </div>
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Search products...">
                <button class="btn btn-primary" type="button">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Product Categories -->
    <h2 class="mb-4">Featured Collections</h2>
    <div class="row">
        <!-- Gourmet Foods Card -->
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <div class="position-relative">
                    <img src="/images/kangaroo.jpg" class="card-img-top product-card-img" alt="Gourmet Foods">
                    <div class="position-absolute bottom-0 start-0 bg-primary text-white px-3 py-2">
                        <i class="fas fa-star me-1"></i> Popular
                    </div>
                </div>
                <div class="card-body">
                    <h3 class="card-title">Gourmet Foods</h3>
                    <p class="card-text">Experience the unique flavors of Australia with premium foods and ingredients.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <button class="btn btn-outline-primary">View Collection</button>
                        <span class="text-muted">15 items</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Home & Gifts Card -->
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <div class="position-relative">
                    <img src="/images/koala.jpg" class="card-img-top product-card-img" alt="Home & Gifts">
                    <div class="position-absolute bottom-0 start-0 bg-success text-white px-3 py-2">
                        <i class="fas fa-leaf me-1"></i> Eco-friendly
                    </div>
                </div>
                <div class="card-body">
                    <h3 class="card-title">Home & Gifts</h3>
                    <p class="card-text">Authentic Australian-made homewares, decorations, and thoughtful gifts.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <button class="btn btn-outline-primary">View Collection</button>
                        <span class="text-muted">12 items</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Souvenirs Card -->
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <div class="position-relative">
                    <img src="/images/spider.jpg" class="card-img-top product-card-img" alt="Souvenirs">
                    <div class="position-absolute bottom-0 start-0 bg-accent text-white px-3 py-2" style="background-color: var(--accent);">
                        <i class="fas fa-bolt me-1"></i> Trending
                    </div>
                </div>
                <div class="card-body">
                    <h3 class="card-title">Souvenirs</h3>
                    <p class="card-text">Take home a piece of Australia with our curated collection of souvenirs.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <button class="btn btn-outline-primary">View Collection</button>
                        <span class="text-muted">8 items</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Best Sellers Section -->
    <div class="d-flex justify-content-between align-items-center mt-5 mb-4">
        <h2 class="mb-0">Best Sellers</h2>
        <a href="#" class="text-decoration-none">View all <i class="fas fa-chevron-right ms-1"></i></a>
    </div>
    
    <div class="row">
        <!-- Product items -->
        @for (int i = 1; i <= 8; i++)
        {
            <div class="col-md-3 col-sm-6 mb-4 fade-in">
                <div class="card product-card h-100">
                    <div class="position-relative">
                        <img src="@($"/images/{(i % 3 == 0 ? "spider" : i % 3 == 1 ? "kangaroo" : "koala")}.jpg")" class="card-img-top" style="height: 180px; object-fit: cover;" alt="Product">
                        @if (i % 4 == 0)
                        {
                            <span class="position-absolute top-0 end-0 bg-danger text-white px-2 py-1 m-2 rounded">SALE</span>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">Premium Aussie @(i % 3 == 0 ? "Souvenir" : i % 3 == 1 ? "Gourmet" : "Gift")</h5>
                        <p class="card-text flex-grow-1">High-quality authentic Australian product with premium features.</p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div>
                                <span class="fw-bold">$@(20 + i * 5).95</span>
                                @if (i % 4 == 0)
                                {
                                    <span class="text-decoration-line-through text-muted ms-2">$@(30 + i * 5).95</span>
                                }
                            </div>
                            <button class="btn btn-sm btn-primary">
                                <i class="fas fa-shopping-cart me-1"></i> Add
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Call to Action -->
    <div class="card bg-light mt-5 border-0" style="background: linear-gradient(135deg, rgba(0,114,178,0.05) 0%, rgba(0,132,61,0.05) 100%) !important;">
        <div class="card-body p-4 text-center">
            <h3>Can't find what you're looking for?</h3>
            <p class="mb-3">Our product specialists are here to help you find the perfect Australian goods.</p>
            <button class="btn btn-primary">
                <i class="fas fa-headset me-2"></i> Contact Support
            </button>
        </div>
    </div>
</div>

<style>
    .product-card-img {
        height: 220px;
        object-fit: cover;
    }
</style>

@section Scripts {
    <script>
        // Add fade-in animation
        document.addEventListener('DOMContentLoaded', function() {
            const elements = document.querySelectorAll('.fade-in');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = 1;
                    }
                });
            });
            
            elements.forEach(element => {
                element.style.opacity = 0;
                observer.observe(element);
            });
        });
    </script>
}

